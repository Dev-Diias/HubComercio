@model HubComercio.Models.ViewModels.FinanceiroViewModel

@{
    ViewData["Title"] = "Painel de Finanças";
}

<div class="container mt-4">
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="m-0">PAINEL DE FINANÇAS</h3>

        <form asp-controller="Financeiro" asp-action="Resetar" method="post"
              onsubmit="return confirm('Tem certeza que deseja resetar o painel? O histórico será reiniciado.');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                Resetar painel
            </button>
        </form>
    </div>
    <div class="card shadow rounded-4 p-4">
        <h3 class="text-center mb-4">PAINEL DE FINANÇAS</h3>

        <div class="row">
            <div class="col-md-6">
                <p><strong>TOTAL DE VENDAS:</strong> @Model.TotalVendas vendas</p>
                <p><strong>TICKET MÉDIO POR VENDA:</strong> @Model.TicketMedio.ToString("C")</p>
                <p><strong>VALOR BRUTO VENDIDO:</strong> @Model.ValorBruto.ToString("C")</p>
            </div>

            <div class="col-md-6">
                <p><strong>PORCENTAGEM DE FORMAS DE PAGAMENTO</strong></p>
                <p>PIX: @Model.PercentualPix.ToString("0.0")%</p>
                <p>CARTÃO DE CRÉDITO: @Model.PercentualCartao.ToString("0.0")%</p>
                <p>DINHEIRO: @Model.PercentualDinheiro.ToString("0.0")%</p>

                <canvas id="graficoPagamento" width="300" height="300"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('graficoPagamento').getContext('2d');

    new Chart(ctx, {
    type: 'pie',
    data: {
    labels: ['PIX', 'Cartão', 'Dinheiro'],
    datasets: [{
    data: [
    @Model.PercentualPix.ToString(System.Globalization.CultureInfo.InvariantCulture),
    @Model.PercentualCartao.ToString(System.Globalization.CultureInfo.InvariantCulture),
    @Model.PercentualDinheiro.ToString(System.Globalization.CultureInfo.InvariantCulture)
    ],
    backgroundColor: ['#f1c40f', '#2ecc71', '#3498db']
    }]
    },
    options: {
    responsive: true
    }
    });
</script>