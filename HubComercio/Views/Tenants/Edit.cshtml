@model HubComercio.Models.Tenant

@{
    ViewData["Title"] = "Editar Tenant";
}

<div class="container mt-4">
    <h4>Editar Tenant</h4>
    <hr />

    <div class="row">
        <div class="col-md-6">

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>

                <input type="hidden" asp-for="Id" />

                @* DataCadastro não deve ser editável *@
                <input type="hidden" asp-for="DataCadastro" />

                @* Mantém URLs atuais caso não troque as imagens *@
                <input type="hidden" asp-for="LogoUrl" />
                <input type="hidden" asp-for="BannerUrl" />

                @if (User.IsInRole("Admin"))
                {
                    <div class="mb-3">
                        <label asp-for="NomeEstabelecimento" class="form-label">Nome do Estabelecimento</label>
                        <input asp-for="NomeEstabelecimento" class="form-control" />
                        <span asp-validation-for="NomeEstabelecimento" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CNPJ" class="form-label">CNPJ</label>
                        <input asp-for="CNPJ" class="form-control" />
                        <span asp-validation-for="CNPJ" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Ativo" />
                        <label class="form-check-label" asp-for="Ativo">Ativo</label>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Logo atual</label><br />
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="Logo" style="max-height: 110px;" class="rounded shadow-sm" />
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Trocar logo (opcional)</label>
                    <input type="file" name="logo" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Banner atual</label><br />
                    @if (!string.IsNullOrEmpty(Model.BannerUrl))
                    {
                        <img src="@Model.BannerUrl" alt="Banner" style="max-width: 100%; max-height: 180px;" class="rounded shadow-sm" />
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Trocar banner (opcional)</label>
                    <input type="file" name="banner" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label asp-for="CorPrincipal" class="form-label">Cor Principal da Marca</label>
                    <input asp-for="CorPrincipal" type="color" class="form-control form-control-color" />
                    <span asp-validation-for="CorPrincipal" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}