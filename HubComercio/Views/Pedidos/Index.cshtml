@model IEnumerable<HubComercio.Models.Pedido>
@using HubComercio.Models
@using System.Globalization

@{
    ViewData["Title"] = "Pedidos Ativos";
    var cultura = new CultureInfo("pt-BR");
}

<h2 class="mb-4">Pedidos Ativos</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text"
               name="busca"
               class="form-control"
               placeholder="Buscar pelo número do pedido"
               value="@Context.Request.Query["busca"]" />

        <button type="submit" class="btn btn-primary">
            Buscar
        </button>

        <a asp-action="Index" class="btn btn-outline-secondary">
            Limpar
        </a>
    </form>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Historico" class="btn btn-dark">
            Ver histórico
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhum pedido ativo no momento.
    </div>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Pedido</th>
                <th>Data</th>
                <th>Total</th>
                <th>Pagamento</th>
                <th>Entrega</th>
                <th>Status</th>
                <th>Itens</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>#@pedido.IdPedido</td>
                    <td>@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@pedido.ValorTotal.ToString("C", cultura)</td>
                    <td>@pedido.FormaPagamento</td>
                    <td>@pedido.EnderecoEntrega</td>
                    <td>
                        @switch (pedido.Status)
                        {
                            case StatusPedido.Pendente:
                                <span class="badge bg-warning text-dark">Pendente</span>
                                break;
                            case StatusPedido.EmPreparacao:
                                <span class="badge bg-primary">Em preparação</span>
                                break;
                        }
                    </td>
                    <td>
                        <ul class="mb-0 ps-3">
                            @foreach (var item in pedido.Itens)
                            {
                                <li>
                                    @item.NomeProduto -
                                    @item.Quantidade.ToString("0.###", cultura) @item.UnidadeMedida -
                                    @item.TotalItem.ToString("C", cultura)
                                </li>
                            }
                        </ul>
                    </td>
                    <td>
                        @if (pedido.Status == StatusPedido.Pendente)
                        {
                            <form asp-action="IniciarPreparacao" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pedido.IdPedido" />
                                <button type="submit" class="btn btn-sm btn-primary mb-1">
                                    Iniciar preparo
                                </button>
                            </form>

                            <form asp-action="Cancelar" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pedido.IdPedido" />
                                <button type="submit" class="btn btn-sm btn-danger mb-1">
                                    Cancelar
                                </button>
                            </form>
                        }
                        else if (pedido.Status == StatusPedido.EmPreparacao)
                        {
                            <form asp-action="Concluir" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pedido.IdPedido" />
                                <button type="submit" class="btn btn-sm btn-success mb-1">
                                    Concluir
                                </button>
                            </form>

                            <form asp-action="Cancelar" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pedido.IdPedido" />
                                <button type="submit" class="btn btn-sm btn-danger mb-1">
                                    Cancelar
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
@section Scripts {
    <script>
        let ultimoPedidoAtual = @(Model.Any() ? Model.Max(p => p.IdPedido) : 0);

        setInterval(async function () {
            try {
                const response = await fetch('@Url.Action("VerificarNovosPedidos", "Pedidos")', {
                    method: 'GET',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    console.error('Erro na requisição:', response.status);
                    return;
                }

                const data = await response.json();

                if (!data.sucesso) {
                    console.warn('Não foi possível verificar novos pedidos.');
                    return;
                }

                if (data.ultimoPedidoId > ultimoPedidoAtual) {
                    location.reload();
                }
            } catch (error) {
                console.error('Erro ao verificar novos pedidos:', error);
            }
        }, 5000);
    </script>
}