@model IEnumerable<HubComercio.Models.Pedido>
@using HubComercio.Models
@using System.Globalization

@{
    ViewData["Title"] = "Histórico de Pedidos";
    var cultura = new CultureInfo("pt-BR");
}

<h2 class="mb-4">Histórico de Pedidos</h2>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">
        @TempData["Sucesso"]
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex gap-2 flex-wrap">
        <input type="text"
               name="busca"
               class="form-control"
               placeholder="Buscar pelo número do pedido"
               value="@Context.Request.Query["busca"]" />

        <button type="submit" class="btn btn-primary">
            Buscar
        </button>

        <a asp-action="Historico" class="btn btn-outline-secondary">
            Limpar
        </a>
    </form>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-dark">
            Voltar para pedidos ativos
        </a>

        <form asp-action="LimparHistorico" method="post"
              onsubmit="return confirm('Tem certeza que deseja apagar todos os pedidos concluídos e cancelados do histórico?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                Limpar histórico
            </button>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhum pedido encontrado no histórico.
    </div>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Pedido</th>
                <th>Data</th>
                <th>Total</th>
                <th>Pagamento</th>
                <th>Entrega</th>
                <th>Status</th>
                <th>Itens</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>#@pedido.IdPedido</td>
                    <td>@pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@pedido.ValorTotal.ToString("C", cultura)</td>
                    <td>@pedido.FormaPagamento</td>
                    <td>@pedido.EnderecoEntrega</td>
                    <td>
                        @switch (pedido.Status)
                        {
                            case StatusPedido.Pendente:
                                <span class="badge bg-warning text-dark">Pendente</span>
                                break;
                            case StatusPedido.EmPreparacao:
                                <span class="badge bg-primary">Em preparação</span>
                                break;
                            case StatusPedido.Concluido:
                                <span class="badge bg-success">Concluído</span>
                                break;
                            case StatusPedido.Cancelado:
                                <span class="badge bg-danger">Cancelado</span>
                                break;
                        }
                    </td>
                    <td>
                        <ul class="mb-0 ps-3">
                            @foreach (var item in pedido.Itens)
                            {
                                <li>
                                    @item.NomeProduto -
                                    @item.Quantidade.ToString("0.###", cultura) @item.UnidadeMedida -
                                    @item.TotalItem.ToString("C", cultura)
                                </li>
                            }
                        </ul>
                    </td>
                    <td>
                        <span class="text-muted">Sem ações</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}