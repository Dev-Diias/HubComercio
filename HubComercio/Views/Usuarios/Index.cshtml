@model IEnumerable<HubComercio.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">👥 Usuários</h2>
        <a asp-action="Create" class="btn btn-success">
            + Novo Usuário
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Email</th>
                        <th>Cargo</th>
                        <th>Estabelecimento</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
@foreach (var item in Model) {
                    <tr>
                        <td class="fw-semibold">@item.Nome</td>
                        <td>@item.Telefone</td>
                        <td>@item.Email</td>
                        <td>
                            <span class="badge bg-primary">
                                @item.Cargo
                            </span>
                        </td>
                        <td>
                            @(item.Tenant != null ? item.Tenant.NomeEstabelecimento : "—")
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.IdUsuario" 
                               class="btn btn-sm btn-outline-warning me-1">
                                ✏️
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.IdUsuario" 
                               class="btn btn-sm btn-outline-danger">
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>