@{
    ViewData["Title"] = "Painel de Gestão";
}

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h3 class="mb-0">Painel de Gestão</h3>
            <small class="text-muted">Acesse rapidamente as áreas do sistema.</small>
        </div>
    </div>

    <div class="row g-3">

        <div class="col-12 col-md-6 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Categorias</h5>
                    <p class="card-text text-muted">
                        Crie, edite e organize as categorias do seu catálogo.
                    </p>
                    <a class="btn btn-primary"
                       asp-controller="Categorias"
                       asp-action="Index">
                        Gerenciar categorias
                    </a>
                    <a class="btn btn-outline-secondary ms-2"
                       asp-controller="Categorias"
                       asp-action="Create">
                        Nova categoria
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Produtos</h5>
                    <p class="card-text text-muted">
                        Cadastre produtos, preços e imagens do seu catálogo.
                    </p>

                    <a class="btn btn-primary"
                       asp-controller="Produtos"
                       asp-action="Index">
                        Gerenciar produtos
                    </a>

                    <a class="btn btn-outline-secondary ms-2"
                       asp-controller="Produtos"
                       asp-action="Create">
                        Novo produto
                    </a>

                    @* Se você ainda não tem ProdutosController, comenta esses links *@
                </div>
            </div>
        </div>

    </div>
</div>