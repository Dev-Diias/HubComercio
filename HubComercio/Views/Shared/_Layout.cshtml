<!DOCTYPE html>
<html lang="pt-br">
@{
        var tenantId = User.FindFirst("TenantId")?.Value;
        var isDev = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";
}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HubComercio</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HubComercio.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">HubComercio</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                                               
                        @* ===== MENU DE DESENVOLVIMENTO (aparece só em Development) ===== *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Tenants" asp-action="Index">Tenants</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        <span class="badge rounded-pill bg-primary-subtle text-primary border">
                            Tenant: @(tenantId ?? "sem tenant")
                        </span>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <div class="dropdown user-menu">
                                <button class="btn user-menu-button dropdown-toggle d-flex align-items-center gap-2"
                                        type="button"
                                        id="userMenuDropdown"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                
                                    <div class="user-avatar">
                                        @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    </div>

                                    <div class="text-start d-none d-md-block">
                                        <div class="user-name">@User.Identity.Name</div>
                                        <small class="user-role text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                                    </div>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 user-dropdown" aria-labelledby="userMenuDropdown">
                                    <li class="dropdown-header px-3 py-2">
                                        <div class="fw-semibold">@User.Identity.Name</div>
                                        <small class="text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</small>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2"
                                                   asp-controller="Tenants"
                                                   asp-action="Index">
                                                <i class="bi bi-gear"></i>
                                                Configuração da loja
                                            </a>
                                        </li>
                                    }
                                    else
                                    {
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center gap-2"
                                                   asp-controller="Tenants"
                                                   asp-action="MinhaLoja">
                                                <i class="bi bi-gear"></i>
                                                Configuração da loja
                                            </a>
                                        </li>
                                    }

                                    @if (User.IsInRole("Administrador") || User.IsInRole("Admin") || User.IsInRole("adm"))
                                    {
                                        <li>
                                        <a asp-controller="Usuarios"
                                               asp-action="Index"
                                               class="d-flex align-items-center text-decoration-none text-light py-2 px-3">
                                            <span class="me-2">👤</span>
                                            <span>Usuários</span>
                                        </a>
                                        </li>
                                    }

                                    <li>
                                        <a asp-controller="Financeiro" asp-action="Index" class="dropdown-item d-flex align-items-center gap-2">
                                            <i class="bi bi-bar-chart-line"></i>
                                            Finanças
                                        </a>
                                    </li>

                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item d-flex align-items-center gap-2 text-danger">
                                                <i class="bi bi-box-arrow-right"></i>
                                                Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HubComercio - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>