@model HubComercio.Models.Categoria

@{
    ViewData["Title"] = "Nova Categoria";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <div class="mb-4">
                        <h3 class="fw-bold mb-1">Nova Categoria</h3>
                        <p class="text-muted mb-0">
                            Cadastre uma nova categoria para organizar melhor os produtos do seu catálogo.
                        </p>
                    </div>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3" role="alert"></div>
                        }

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label fw-semibold">Nome da Categoria</label>
                            <input asp-for="Nome" class="form-control form-control-lg" placeholder="Ex: Bebidas, Mercearia, Lanches..." />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Imagem da Categoria</label>
                            <input type="file" name="foto" class="form-control" id="fotoInput" accept="image/*" />
                            <div class="form-text">
                                O envio da imagem é opcional.
                            </div>
                        </div>

                        <div class="mb-4 text-center">
                            <img id="previewImagem"
                                 src="/imagens/sem-imagem.png"
                                 alt="Pré-visualização da imagem"
                                 class="img-fluid rounded-3 border shadow-sm"
                                 style="max-height: 180px; object-fit: cover;" />
                        </div>

                        <div class="d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-primary px-4">Salvar Categoria</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Voltar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const fotoInput = document.getElementById('fotoInput');
        const previewImagem = document.getElementById('previewImagem');

        fotoInput.addEventListener('change', function () {
            const arquivo = this.files[0];

            if (arquivo) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImagem.src = e.target.result;
                };
                reader.readAsDataURL(arquivo);
            } else {
                previewImagem.src = '/imagens/sem-imagem.png';
            }
        });
    </script>
}