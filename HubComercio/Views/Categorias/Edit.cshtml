@model HubComercio.Models.Categoria

@{
    ViewData["Title"] = "Editar Categoria";
}

<div class="container mt-4">
    <h4>Editar Categoria</h4>
    <hr />

    <div class="row">
        <div class="col-md-6">

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>

                <input type="hidden" asp-for="IdCategoria" />
                <input type="hidden" asp-for="ImagemUrl" /> @* mantém a imagem atual caso não envie outra *@

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome da Categoria</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagem atual</label>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                        {
                            <img src="@Model.ImagemUrl" alt="Imagem da categoria" style="max-height:120px;" />
                        }
                        else
                        {
                            <div class="text-muted">Sem imagem</div>
                        }
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Trocar imagem (opcional)</label>
                    <input type="file" name="foto" class="form-control" />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}