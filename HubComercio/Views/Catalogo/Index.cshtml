@model HubComercio.Models.ViewModels.CatalogoViewModel
@using System.Globalization
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Catálogo - @Model.NomeEstabelecimento</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            background-color: #0f1120;
            color: white;
        }

        .topo-catalogo {
            background-color: @(string.IsNullOrWhiteSpace(Model.CorPrincipal) ? "#36248f" : Model.CorPrincipal);
            padding: 20px 0;
        }

        .logo-loja {
            max-height: 90px;
            max-width: 180px;
            object-fit: contain;
            border-radius: 10px;
            background: white;
            padding: 6px;
        }

        .banner-loja {
            width: 100%;
            max-height: 280px;
            object-fit: cover;
            border-radius: 12px;
            margin-bottom: 25px;
        }

        .card {
            background-color: #1a1d33;
            color: white;
            border: none;
            border-radius: 12px;
        }

        .card-title {
            color: white;
        }

        .card-text {
            color: #bfc3d9 !important;
        }

        .card-price {
            color: @(string.IsNullOrWhiteSpace(Model.CorPrincipal) ? "#36248f" : Model.CorPrincipal);
            font-weight: bold;
        }

        .navbar-brand-area {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .nome-loja {
            margin: 0;
            font-size: 2rem;
            font-weight: bold;
            color: white;
        }
    </style>
</head>
<body>

    <div class="topo-catalogo shadow-sm mb-4">
        <div class="container">
            <div class="navbar-brand-area">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" alt="Logo da loja" class="logo-loja" />
                }

                <h1 class="nome-loja">@Model.NomeEstabelecimento</h1>
            </div>
        </div>
    </div>

    <div class="container">

        @if (!string.IsNullOrEmpty(Model.BannerUrl))
        {
            <img src="@Model.BannerUrl" alt="Banner da loja" class="banner-loja shadow" />
        }

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model.Produtos)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="@item.ImagemUrl" class="card-img-top" alt="@item.Nome" style="height: 180px; object-fit: cover;">

                        <div class="card-body">
                            <h5 class="card-title">@item.Nome</h5>
                            <p class="card-text mb-2">@item.Categoria?.Nome</p>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="card-price h5 mb-0">
                                    @item.Preco.ToString("C", new CultureInfo("pt-BR"))
                                </span>
                                <span class="badge bg-light text-dark">@item.UnidadeMedida</span>
                            </div>

                            <a href="https://wa.me/5518999999999?text=Olá, vi o seu catálogo e quero: @item.Nome"
                               target="_blank"
                               class="btn btn-success w-100 shadow-sm">
                                Pedir no WhatsApp
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

</body>
</html>