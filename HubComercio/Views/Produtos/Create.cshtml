@model HubComercio.Models.Produto

@{
    ViewData["Title"] = "Novo Produto";
    var categorias = ViewBag.Categorias as IEnumerable<dynamic>;
}

<div class="container mt-4">
    <h4>Criar Produto</h4>
    <hr />

    <div class="row">
        <div class="col-md-6">

            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Preco" class="form-label">Preço</label>
                    <input asp-for="Preco" class="form-control" type="number" step="0.01" lang="pt-BR" />
                    <span asp-validation-for="Preco" class="text-danger"></span>
                    <small class="text-muted">Pode digitar 12.90 ou 12,90.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="UnidadeMedida" class="form-label">Unidade de Medida</label>
                    <input asp-for="UnidadeMedida" class="form-control" placeholder="Ex: kg ou un" />
                    <span asp-validation-for="UnidadeMedida" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Qtde" class="form-label">Quantidade</label>
                    <input asp-for="Qtde" class="form-control" />
                    <span asp-validation-for="Qtde" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagem do Produto</label>
                    <input type="file" name="foto" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label asp-for="CategoriaId" class="form-label">Categoria</label>
                    <select asp-for="CategoriaId" class="form-control">
                        <option value="">Selecione...</option>
                        @if (categorias != null)
                        {
                            foreach (var c in categorias)
                            {
                                <option value="@c.IdCategoria">@c.Nome</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}