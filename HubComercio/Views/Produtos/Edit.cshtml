@model HubComercio.Models.Produto

@{
    ViewData["Title"] = "Editar Produto";
    var categorias = ViewBag.Categorias as IEnumerable<dynamic>;
    int? categoriaSelecionada = ViewBag.CategoriaSelecionada as int?;
}

<div class="container mt-4">
    <h4>Editar Produto</h4>
    <hr />

    <div class="row">
        <div class="col-md-6">

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="All" class="text-danger"></div>

                <input type="hidden" asp-for="IdProduto" />

                <div class="mb-3">
                    <label asp-for="Nome" class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Preco" class="form-label">Preço</label>
                    <input asp-for="Preco" class="form-control" type="number" step="0.01" lang="pt-BR" />
                    <span asp-validation-for="Preco" class="text-danger"></span>
                    <small class="text-muted">Pode digitar 12.90 ou 12,90.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label d-block">Unidade de Medida</label>

                    <div class="form-check form-check-inline">
                        <input class="form-check-input" asp-for="UnidadeMedida" type="radio" value="kg" id="unidadeKg" />
                        <label class="form-check-label" for="unidadeKg">kg</label>
                    </div>

                    <div class="form-check form-check-inline">
                        <input class="form-check-input" asp-for="UnidadeMedida" type="radio" value="un" id="unidadeUn" />
                        <label class="form-check-label" for="unidadeUn">un</label>
                    </div>

                    <span asp-validation-for="UnidadeMedida" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Qtde" class="form-label">Quantidade</label>

                    <input asp-for="Qtde" class="form-control" type="text" placeholder="Ex: 10 ou 1,250" />

                    <span asp-validation-for="Qtde" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagem atual</label>
                    <div>
                        @if (!string.IsNullOrEmpty(Model.ImagemUrl))
                        {
                            <img src="@Model.ImagemUrl" alt="Imagem atual"
                                 style="width:120px;height:120px;object-fit:cover;border-radius:10px;" />
                        }
                        else
                        {
                            <span class="text-muted">Sem imagem</span>
                        }
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Trocar imagem (opcional)</label>
                    <input type="file" name="foto" class="form-control" accept="image/*" />
                </div>

                <div class="mb-3">
                    <label asp-for="CategoriaId" class="form-label">Categoria</label>
                    <select asp-for="CategoriaId" class="form-control">
                        <option value="">Selecione...</option>
                        @if (categorias != null)
                        {
                            foreach (var c in categorias)
                            {
                                // seleciona a categoria atual
                                var selected = (categoriaSelecionada.HasValue && (int)categoriaSelecionada.Value == (int)c.IdCategoria)
                                ? "selected"
                                : "";

                                <option value="@c.IdCategoria" selected="@selected">@c.Nome</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Salvar</button>
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}